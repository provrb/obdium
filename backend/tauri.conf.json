{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "frontendDist": "../frontend"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "./data/vpic.sqlite.xz",
      "./data/code-descriptions.sqlite",
      "./data/model-pids.sqlite"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "obdium",
  "mainBinaryName": "obdium",
  "version": "1.5.0",
  "identifier": "com.obdium.app",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OBDium",
        "height": 700,
        "width": 1200,
        "minHeight": 400,
        "minWidth": 1025,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}